# test_pbc_distance.vsim
# Parser test: pbc.distance configuration
# Expression-level execution: WO-57C

[project]
name        = test_pbc_distance
version     = v5.0.0-beta.8
determinism = true

[cell]
type    = orthorhombic
lengths = 10.0, 10.0, 10.0
units   = angstrom

[boundary]
x = periodic
y = periodic
z = periodic

