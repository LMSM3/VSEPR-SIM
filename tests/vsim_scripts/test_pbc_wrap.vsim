# test_pbc_wrap.vsim
# Parser test: [cell] + [boundary] + pbc.wrap behavior
# Parsed by test_pbc_vsim_parser.cpp (Group 57B)
# Expression-level assert execution: WO-57C

[project]
name        = test_pbc_wrap
version     = v5.0.0-beta.8
determinism = true

[cell]
type    = orthorhombic
lengths = 10.0, 10.0, 10.0
units   = angstrom

[boundary]
x = periodic
y = periodic
z = periodic

[pbc]
minimum_image        = true
wrap_positions       = after_step
track_images         = true
unwrap_for_diffusion = true

