# test_pbc_image_count.vsim
# Parser test: track_images enabled + pbc.image_count syntax
# Expression-level execution: WO-57C

[project]
name        = test_pbc_image_count
version     = v5.0.0-beta.8
determinism = true

[cell]
type    = orthorhombic
lengths = 10.0, 10.0, 10.0
units   = angstrom

[boundary]
x = periodic
y = periodic
z = periodic

[pbc]
track_images          = true
unwrap_for_diffusion  = true

