  "feature_adoption_plan": {
    "immediate_c++23": [
      "std::expected<T,E> for fallible operations (molecule resolution, property lookup)",
      "std::optional monadic ops (and_then, transform) for chain-style processing",
      "std::to_underlying for enum conversions",
      "std::unreachable for exhaustive switch coverage",
      "consteval for compile-time validation functions",
      "std::print/std::println where available (GCC 14+)"
    ],
    "near_term_c++23": [
      "std::flat_map for hot-path property lookups",
      "deducing this for CRTP elimination",
      "multidimensional subscript for tensor/matrix types",
      "std::generator for lazy property iteration"
    ],
    "future_c++26": [
      "Contracts (pre/post conditions on kernel APIs)",
      "std::execution for async experiment pipelines",
      "Reflection for automatic serialization",
      "std::inplace_vector for fixed-capacity hot-path containers",
      "std::simd for vectorized property computation"
    ]
  }
