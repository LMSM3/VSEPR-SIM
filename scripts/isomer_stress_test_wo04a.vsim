# scripts/isomer_stress_test_wo04a.vsim
# =============================================================================
# WO-VSIM-04A — Isomer Detection Stress Test
# Formal VSIM language declaration for the stress run.
#
# This script documents the configuration driving the companion C++ stress
# harness (tests/stress_isomer_pipeline.cpp).
#
# Candidate set: ~1,200 hand-constructed and procedurally-varied graphs
# spanning the Phase 1–3 test families from the WO-VSIM-04A specification.
#
# Run via:
#   build/tests/stress_isomer_pipeline.exe
# =============================================================================

[project]
name        = "isomer_stress_test_wo04a"
description = "Stress test: thousands of isomer candidates through the full pipeline"
version     = "v5.0.0-beta.7"
seed_base   = 4200

[analysis.isomers]
enabled              = true
mode                 = "graph_geometry"

formula_guard        = true
graph_validation     = true
valence_check        = true
connectivity_check   = true
formal_charge_check  = true
radical_check        = false

bond_source          = "explicit"

canonical_hash       = true
geometry_rmsd        = false
relaxation_check     = false

known_database_check = false

allow_fragments      = false
allow_charged        = false
allow_radicals       = false
allow_strained       = true

max_bond_order       = 3
bond_tolerance_scale = 1.20
rmsd_tolerance       = 0.05
angle_tolerance_deg  = 3.0

report_level         = "detailed"

[generator.isomers]
enabled        = true
formula        = "C2H2O2"
allow_strained = true
max_bond_order = 3
deduplicate    = "canonical_graph_hash"

[output]
write_report = true
report_path  = "reports/isomer_stress_report.md"
table_path   = "reports/isomer_stress_table.csv"
graph_path   = "reports/isomer_stress_graphs.json"
